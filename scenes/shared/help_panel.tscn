[gd_scene format=3]

[node name="HelpPanel" type="PanelContainer"]
visible = false
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -600.0
offset_top = -420.0
offset_right = 600.0
offset_bottom = 420.0

[node name="HelpMargin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 48
theme_override_constants/margin_top = 36
theme_override_constants/margin_right = 48
theme_override_constants/margin_bottom = 36

[node name="HelpVBox" type="VBoxContainer" parent="HelpMargin"]
layout_mode = 2
theme_override_constants/separation = 24

[node name="Title" type="Label" parent="HelpMargin/HelpVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 54
text = "How to Play"
horizontal_alignment = 1

[node name="ScrollContainer" type="ScrollContainer" parent="HelpMargin/HelpVBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="Content" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 18

[node name="MovementSection" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer/Content"]
layout_mode = 2

[node name="MovementTitle" type="Label" parent="HelpMargin/HelpVBox/ScrollContainer/Content/MovementSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
text = "Movement"

[node name="MovementText" type="RichTextLabel" parent="HelpMargin/HelpVBox/ScrollContainer/Content/MovementSection"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
text = "Use Arrow Keys or WASD to move the cursor. Press Z or Enter to select a unit. Each unit can move once per turn.
\nMovement range is shown by highlighted tiles in blue. Move to the desired tile and press Z to confirm."

[node name="CombatSection" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer/Content"]
layout_mode = 2

[node name="CombatTitle" type="Label" parent="HelpMargin/HelpVBox/ScrollContainer/Content/CombatSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
text = "Combat"

[node name="CombatText" type="RichTextLabel" parent="HelpMargin/HelpVBox/ScrollContainer/Content/CombatSection"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
text = "To attack an enemy, move next to them and select \"Attack\" from the action menu. When a unit is selected, orange tiles show the attack range available after moving. Combat is automatic based on your unit's stats and weapon.
\n
Weapon Triangle: Sword beats Axe, Axe beats Lance, Lance beats Sword.
\n
Magic attacks use RESISTANCE, physical attacks use DEFENSE.
\n
If two allies with a conversation are standing next to each other, the action menu will show \"Talk\"."

[node name="TerrainSection" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer/Content"]
layout_mode = 2

[node name="TerrainTitle" type="Label" parent="HelpMargin/HelpVBox/ScrollContainer/Content/TerrainSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
text = "Terrain"

[node name="TerrainText" type="RichTextLabel" parent="HelpMargin/HelpVBox/ScrollContainer/Content/TerrainSection"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
text = "Forest: +20 AVOID, +1 DEF
Sand: Slows movement, no AVOID bonus
Road: Standard terrain
River: Impassable terrain
Village: End movement here, then choose Visit
Store: End movement here, then choose Visit to buy a Potion for 8 Gold or a weapon upgrade for 35 Gold
Castle: Fortified terrain
Mountain: Impassable terrain
Tall Mountain: Costs a full turn to cross
Shrine: +30 AVOID, +2 DEF"

[node name="ExperienceSection" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer/Content"]
layout_mode = 2

[node name="ExperienceTitle" type="Label" parent="HelpMargin/HelpVBox/ScrollContainer/Content/ExperienceSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
text = "Experience & Leveling"

[node name="ExperienceText" type="RichTextLabel" parent="HelpMargin/HelpVBox/ScrollContainer/Content/ExperienceSection"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
text = "Defeating enemies grants Experience Points (XP). Collecting 100 XP levels up a unit, increasing their stats based on class growth rates.
\n
Knights: High HP/DEF growth
Mages: High MAG growth
Outriders: Balanced growth
Hunters: High SKL growth"

[node name="TurnsSection" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer/Content"]
layout_mode = 2

[node name="TurnsTitle" type="Label" parent="HelpMargin/HelpVBox/ScrollContainer/Content/TurnsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
text = "Turns & Actions"

[node name="TurnsText" type="RichTextLabel" parent="HelpMargin/HelpVBox/ScrollContainer/Content/TurnsSection"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
text = "Your Turn: Move and act with each of your units once. When done, press T to open an end-turn confirmation.
\n
Enemy Turn: Enemy AI will move and attack. Defeat all enemies to win!
\n
Reinforcements may arrive on certain turns - watch for messages!
\n
Press P during your phase to open the System menu for Suspend Save or Restart Chapter."

[node name="ControlsSection" type="VBoxContainer" parent="HelpMargin/HelpVBox/ScrollContainer/Content"]
layout_mode = 2

[node name="ControlsTitle" type="Label" parent="HelpMargin/HelpVBox/ScrollContainer/Content/ControlsSection"]
layout_mode = 2
theme_override_font_sizes/font_size = 42
text = "Controls"

[node name="ControlsText" type="RichTextLabel" parent="HelpMargin/HelpVBox/ScrollContainer/Content/ControlsSection"]
layout_mode = 2
bbcode_enabled = false
fit_content = true
text = "Arrow Keys / WASD: Move cursor
Z / Enter: Select / Confirm
X / Escape: Cancel / Back
I: Inspect unit under cursor
Hover an enemy: Show that enemy's exact threat tiles, current player targets, and combat preview for a selected ally
V: Toggle enemy danger zone (gold-rimmed tiles mark boss threat)
P: Open system menu
T: End-turn confirmation
Space: Skip battle animation"

[node name="CloseButton" type="Button" parent="HelpMargin/HelpVBox"]
layout_mode = 2
text = "Close (Press X or Escape)"
