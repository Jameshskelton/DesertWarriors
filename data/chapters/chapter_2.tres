event_triggers = []
opening_dialogue = [{
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Narrator",
"text": "The road east stretches through open plains, the Greenwood thinning behind them. Ember leads the way, her eyes scanning for familiar landmarks—a burned mill, a hollow oak, the stone marker of an old covenant."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Ember",
"text": "The monastery stands at the crossroads of old trade routes. When the Verdant Kingdom was young, the monks there served as healers for both king and commoner alike.The current abbot... Abbot Vermis. He was a friend to your father once. Whether he remains a friend to your memory, I cannot say."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Woody",
"text": "We have little choice but to try. The resistance Brother Hale spoke of—if it exists—we need their numbers. We cannot win this with five souls."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Rowan",
"text": "Cavalry scouts ahead, my prince. Royal lancers by their banners, not mere brigands. They know we're coming."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Bram",
"text": "Then we ride through them. My shield has stopped better blades than theirs. Let them come."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Brother Hale",
"text": "The spirits of the road whisper warning. I sense treachery ahead—not from the knights, but from within the monastery walls themselves.Trust nothing until you see the abbot's true face, Woody. Old alliances rot quickly in the shadow of crowns."
}]
victory_dialogue = [{
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Abbot Vermis",
"text": "Enough! I did not become abbot by being a fool. Your father saved my life twenty years ago during the Border Rebellion—I have not forgotten.But neither have I forgotten what happened to him. He was betrayed by those he trusted. If I shelter you, the king's armies will burn this monastery to ash."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Woody",
"text": "Then we will not stay. We only need your blessing, Abbot—and the names of those who still remember the true crown."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Abbot Vermis",
"text": "There is a knight named Sir Aldric, formerly of the Silverguard. He and twelve loyal men have hidden in the canyons to the south. They call themselves the Unbroken.He will not come to you easily—he carries the weight of his oath to the usurper king. But if you can defeat him in fair combat... he may listen."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Ember",
"text": "The southern canyons. I know them well—my family once farmed in the valley below. The Silverguard's shame runs deep; they will not accept a new master easily."
}, {
"chapter": "Chapter 2: The Old Monastery",
"speaker": "Brother Hale",
"text": "The monks offer provisions and healing. We rest here one night, then ride south. Sir Aldric awaits—and with him, the first true test of your claim to the throne."
}]
next_chapter_id = "chapter_3"
