event_triggers = [{
"action": "spawn_join",
"dialogue_lines": [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ricodial",
"text": "George! By the old king's cloak, it really is you! I am Ricodial - your father's reader, letter-writer, and occasional saver of singed draperies."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "Ricodial? I thought my uncle had seized every soul from the old court."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ricodial",
"text": "He tried. When Malrec started hanging servants for remembering Alden fondly, I decided hiding in a valley village was the better professional choice."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ricodial",
"text": "You look like a better banner to me, my prince. Let me join you. I bring respectable fire, indecent optimism, and a memory for every lord who ever dined happily at your father's table."
}],
"id": "ricodial_join",
"message": "Ricodial emerges from the village and gladly rejoins the Verdant cause.",
"position": Vector2i(4, 7),
"spawn": {
"faction": "player",
"instance_id": "ricodial_joined",
"position": Vector2i(5, 7),
"unit_id": "ricodial"
},
"trigger": "tile",
"unit_id": ""
}, {
"boss_id": "sir_aldric",
"dialogue_lines": [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Hold, George. If you would claim men who have buried brothers for the crown's sins, do not do it with speeches from horseback."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "Then judge me at sword's reach."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "I mean to. Your father won my respect because he stood where arrows fell thickest. If you are only Malrec's mirror with gentler words, I will see it in a single charge."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "I did not come to buy loyalty with fear. I came to earn it."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Good. Then let the valley witness whether Alden's blood still carries iron."
}],
"id": "sir_aldric_confront",
"trigger": "boss_confront",
"unit_id": "george"
}, {
"dialogue_lines": [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ricodial",
"text": "The Unbroken glare exactly like court nobles, except with better scars and fewer perfumes."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "Then perhaps we have finally found honest company."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ricodial",
"text": "Honest, yes. Easy, no. We shall have to impress them the old-fashioned way."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "By bleeding for it?"
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ricodial",
"text": "Regrettably, yes."
}],
"id": "chapter_3_talk_george_ricodial",
"trigger": "talk",
"unit_a_id": "george",
"unit_b_id": "ricodial"
}, {
"dialogue_lines": [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ember",
"text": "Keep low when you cross the cobbles. Aldric's riders will watch every open lane."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Balt",
"text": "I can do low. Heroically low."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ember",
"text": "Good. Stay alive long enough and I may even call that courage."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Balt",
"text": "I will treasure the possibility."
}],
"id": "chapter_3_talk_ember_balt",
"trigger": "talk",
"unit_a_id": "ember",
"unit_b_id": "balt"
}, {
"dialogue_lines": [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Bram",
"text": "Aldric still drills his lines well."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Rowan",
"text": "Soldiers who hate their own banner often practice harder."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Bram",
"text": "Then let them see discipline can serve honor instead of fear."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Rowan",
"text": "Good. We win this cleanly, and half the valley may ride with us."
}],
"id": "chapter_3_talk_bram_rowan",
"trigger": "talk",
"unit_a_id": "bram",
"unit_b_id": "rowan"
}]
opening_dialogue = [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Narrator",
"text": "South of the monastery, the land breaks into canyons and hidden farms. George's band reaches a valley where abandoned watchtowers, stubborn cropland, and wary sentries share the same uneasy silence."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Narrator",
"text": "Here the remnants of the Silverguard have made their stand: men who refused Malrec's oath, yet could not forgive themselves for ever wearing the crown that crowned him. They call themselves the Unbroken."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ember",
"text": "My family once traded grain in this valley. Then Malrec's tax riders came, and after them the Silverguard vanished into these hills. The people here learned to keep their heads down and their doors barred."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Rowan",
"text": "Even now their lines are disciplined. Those are not brigands pretending to be soldiers. They still remember the work."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Bram",
"text": "Aye. They stand like men ashamed of the banner they served and unwilling to wear another."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Brother Hale",
"text": "The spirits are restless, but not wrathful. They do not hate these men. They grieve them."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "Then I will not threaten them with birthright alone. If Sir Aldric wants proof, he shall have it."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Halt, travelers. This valley belongs to the Unbroken. State your business plainly, or depart in peace."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "I am George, son of King Alden. I have not come to command your allegiance. I have come to ask whether any of the old kingdom still remembers what it was meant to protect."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "I remember what it protected. That is why I buried good men after Malrec took the throne. If you want the Unbroken, prince, do not ask for us with your father's name on your tongue. Earn us."
}]
victory_dialogue = [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Enough. Enough. That last stroke was Alden's exactly. I have spent three years telling my men there was nothing left in this kingdom worth swearing to, and you have made a liar of me."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "Then swear to the truth instead of the throne that betrayed it."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Gladly. I served your father because he could look a beaten man in the eye without contempt. You fought the same way today. The Unbroken are yours if you will have us."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Bram",
"text": "Thirteen blades, a hidden valley, and a captain who still remembers honor. That is more than we had yesterday."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Rowan",
"text": "That is not a company anymore. That is the beginning of an army."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Brother Hale",
"text": "More than an army. A reckoning. The valley's dead can rest easier tonight."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ember",
"text": "And when Malrec hears Sir Aldric bent the knee, he will know the old fear has changed sides."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "George",
"text": "Then let him fear. We ride for Saint Orin's cloister, and we ride as more than fugitives now."
}]
next_chapter_id = "chapter_4"
