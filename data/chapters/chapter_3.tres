opening_dialogue = [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Narrator",
"text": "The southern canyons open into a hidden valley—a patchwork of farms and watchtowers, half-reclaimed by nature. Here, the Silverguard's remnants have made their final stand: thirteen knights who refused the usurper's oath, led by Sir Aldric of the Verdant Guard."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Woody",
"text": "I see their banners. The silver stag, once the symbol of the king's own guard. They must have torn those from their armor when they fled."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ember",
"text": "They call themselves the Unbroken. Not out of pride—but as a promise. They will not bend again, not for king, not for prince, not for anyone who would ask them to break their oaths."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Halt, travelers. This valley belongs to the Unbroken. State your business, or depart in peace—we have no quarrel with wandering souls."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Woody",
"text": "I am Woody, son of King Alden, heir to the Verdant Throne. I come to claim the allegiance of the Silverguard—as my father once commanded them."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "You are either mad or brave—perhaps both. The king's price for your head would feed my men for a year. Why should I not take it?"
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Bram",
"text": "Because you know in your bones that the throne was stolen. You know the usurper's oath is poison. You've been hiding in this hole, waiting for exactly this moment—for someone worth fighting for."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Words. My brothers in arms have died for less than a traitor's promises. If you want the Unbroken, come and take them. Defeat me in single combat, and my blade—and my oath—will be yours.If you cannot... then flee back to your monastery and leave us to our fate."
}]
victory_dialogue = [{
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "Enough... enough. You fight like your father. He was the only man who ever bested me in the training yard.I swore an oath to defend the Verdant line—not to any crown, but to the blood itself. That blood flows in you. I see that now."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Woody",
"text": "Then the oath is renewed?"
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Sir Aldric",
"text": "A new oath, my prince. The Unbroken are yours. Thirteen blades, ready to ride against the usurper—and whatever armies he sends after us.The road ahead leads to the Valley of Echoes, where the old resistance makes its stand. I will send word ahead. Your father saved lives there, once. They will not forget."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Brother Hale",
"text": "The spirits of the valley whisper welcome. This is no longer a flight—it is a crusade. Word will spread. Other exiles, other broken oaths—they will come.We are no longer fugitives, Woody. We are the seed of a new army."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Rowan",
"text": "I've never seen anything like this. In a single campaign, you've gathered a knight, a mage, a priest, and warriors beyond counting.When we ride on the Valley of Echoes, the usurper will know fear."
}, {
"chapter": "Chapter 3: The Unbroken",
"speaker": "Ember",
"text": "The first chapter ends, but the story continues. The king sits on a throne of lies—we will show him the truth of steel.My village burns no more. Its people may yet return, when the kingdom is whole again. That is enough for me."
}]
