event_triggers = [{
"boss_id": "lysandra_quill",
"dialogue_lines": [{
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Lysandra Quill",
"text": "Prince George. Malrec's heralds promised a chest of silver for your head and a second for anyone who brings it before sunrise. That is a very persuasive dawn."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "George",
"text": "Then my uncle has finally admitted what I am worth to him: not as nephew, but as fear made flesh."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Lysandra Quill",
"text": "Do not make this personal. I hunt wolves, boars, deserters, and princes with the same courtesy. I loose an arrow, collect my fee, and sleep well."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "George",
"text": "That is the difference between us. You can sell a life and call it sleep. I carry the dead whether I want to or not."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Lysandra Quill",
"text": "Fine words. Let us see whether they can stop a hunter who knows how to wait for a heartbeat to open."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "George",
"text": "Come test your silver against my father's blood, then."
}],
"id": "lysandra_quill_confront",
"trigger": "boss_confront",
"unit_id": "george"
}]
opening_dialogue = [{
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Narrator",
"text": "With the Unbroken pledged and the valley finally stirring against Malrec, George leads his companions to Saint Orin's cloister: a weathered monastery whose stone halls once sheltered pilgrims, widows, and every soul too tired to keep running."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Ricodial",
"text": "I remember this place. Saint Orin believed a wall should be thick enough to stop winter and humble enough to invite supper. He would be appalled to know we are using his dining hall as a battlefield."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Sir Aldric",
"text": "Appalled or not, these stones will serve us. I have ridden to gather the Unbroken in full. Hold this cloister until dawn, George, and I will return with enough spears to make Malrec's hunters regret taking coin."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Rowan",
"text": "Riders in the west trees. More in the east. Fast ones. Not levy men."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Balt",
"text": "Hunters, by the look of them. Real ones too. The sort who smile only after they have skinned something."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Brother Hale",
"text": "Then this is no patrol. Malrec has paid for a kill."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Ember",
"text": "Of course he has. Men like your uncle always outsource their courage. It keeps their boots clean."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "George",
"text": "Then we deny him both victory and comfort. We hold the cloister. We hold until dawn. Let every arrow they spend here buy us one more ally by morning."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Narrator",
"text": "Beyond the monastery walls, horns answer from opposite tree lines. Malrec's hired hunt has found its quarry, and the night begins to tighten."
}]
victory_dialogue = [{
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Narrator",
"text": "The eastern sky pales. Horns rise from the valley road below, not with the sharp notes of hunters, but with the measured call of soldiers returning in force."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Lysandra Quill",
"text": "Dawn already? Hnh. Malrec paid for a clean hunt, not a siege against a prince who keeps collecting inconvenient friends. Fall back!"
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Rowan",
"text": "There. You hear it? Aldric's riders. Told you we only had to make the night hate us less than the enemy did."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Bram",
"text": "And we did more than hold. We bled the king's purse dry and sent his best trackers home empty-handed."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Ricodial",
"text": "Which is professionally satisfying. There are few insults crueler than making a hired killer work for free."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "George",
"text": "Let Lysandra carry the lesson back to Malrec: every bribe he spends to bury me only buys another day for the realm to remember my father."
}, {
"chapter": "Chapter 4: Hunters at the Cloister",
"speaker": "Brother Hale",
"text": "Then let us greet the morning properly. The cloister stands, the hunters flee, and the kingdom has survived one more night without bowing to fear."
}]
next_chapter_id = null
