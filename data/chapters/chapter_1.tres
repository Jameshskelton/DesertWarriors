reinforcements = [{
"faction": "player",
"dialogue_lines": [{
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Rowan",
"text": "Prince George! About time I found you. Rowan of the South Road riders, late as ever."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "Rowan? I thought my uncle had bought every horse between here and the capital."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Rowan",
"text": "He bought plenty. He also hanged my captain for refusing to trample refugees beneath royal hooves. I would rather ride for the man his new king fears."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Bram",
"text": "Then lower your lance and prove it."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Rowan",
"text": "Gladly. Point me at the crown's dogs."
}],
"instance_id": "rowan_arrival",
"message": "Rowan gallops in from the southern road to reinforce George.",
"position": Vector2i(0, 10),
"turn": 2,
"unit_id": "rowan"
}, {
"faction": "enemy",
"instance_id": "brigand_ambush",
"message": "Another brigand slips out from the eastern brush!",
"position": Vector2i(19, 7),
"turn": 3,
"unit_id": "brigand_grunt"
}]
event_triggers = [{
"action": "spawn_join",
"dialogue_lines": [{
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Ember",
"text": "Hold. I know your face from the warrants, George. Malrec's men nailed them to my door after they took my grain and called it tax."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "Then you know my quarrel with them is no courtly spat."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Ember",
"text": "Maybe. But quarrels are cheap. You fought brigands outside my village without demanding food, gold, or obedience. That is rarer than princes."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Brother Hale",
"text": "Will you stand with us, then?"
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Ember",
"text": "Aye. My village will not burn a third time. I am Ember, and my fire is yours until the usurper answers for what he has done."
}],
"id": "ember_join",
"message": "Ember steps from the village and vows to burn back George's hunters.",
"position": Vector2i(15, 3),
"spawn": {
"faction": "player",
"instance_id": "ember_joined",
"position": Vector2i(16, 3),
"unit_id": "ember"
},
"trigger": "tile",
"unit_id": ""
}, {
"boss_id": "captain_briar",
"dialogue_lines": [{
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Captain Briar",
"text": "Well met, Prince George. Your uncle Malrec promised me ten thousand crowns, a barony, and a place at his table for your head."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "Then he values blood more than loyalty."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Captain Briar",
"text": "Loyalty? Alden ruled like a father, and fathers grow old. Malrec understands fear. Fear keeps roads clear, granaries full, and lesser men obedient."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Bram",
"text": "Fear also breeds graves."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Captain Briar",
"text": "Then I will dig one more. When I send your corpse back to the capital, Malrec will hang your father's banner beneath it and call the realm healed."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "Come claim your reward, then. I would rather die with steel in hand than live beneath my uncle's lie."
}],
"id": "captain_briar_confront",
"trigger": "boss_confront",
"unit_id": "george"
}]
opening_dialogue = [{
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Narrator",
"text": "Three months ago, King Alden died before the court could hear his final will. Before the candles around his bier had burned low, his younger brother Malrec accused Prince George of treason and seized the Verdant Throne for himself."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Narrator",
"text": "Malrec had envied his brother all his life - the crown, the love of the people, even the loyalty George inspired by merely standing beside his father. So he bought judges, frightened captains, and turned jealousy into law."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "My uncle smiled when he named me traitor. He took my father's ring from a dead hand and called the theft justice. If I live long enough, I will make him answer for that smile."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Bram",
"text": "I guarded your father for twelve winters. I watched Malrec's jackals drag honest soldiers out in chains, and I watched my own manor burn for refusing their oath. I do not follow you out of pity, my prince. I follow because I swore to guard Alden's blood."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Brother Hale",
"text": "And I follow because Malrec has profaned every shrine he touches. He taxes the poor, flatters the cruel, and calls it order. The old spirits do not speak often, but when your father died they spoke plainly: the rightful line still walks."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "Then we walk together. Not to reclaim velvet cushions and court songs, but to tear a liar from my father's seat and give this kingdom leave to breathe again."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Bram",
"text": "Good. Vengeance is easier to carry when it is shared."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Brother Hale",
"text": "The Greenwood will hide us while it can. Every oak is a wall, every thicket a veil, and every honest soul Malrec has wronged is a spark waiting for wind."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Narrator",
"text": "A horn sounds in the north. Royal hunters are already in the Greenwood, tracking the prince through the undergrowth like a prize stag. Ahead, a village smokes on the horizon. Beyond it lies an old monastery, and perhaps the first allies George can truly call his own."
}]
victory_dialogue = [{
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Captain Briar",
"text": "So this is Alden's son. Still standing when every calculation said you would break. No wonder Malrec wants you dead before the realm sees you."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Captain Briar",
"text": "He told me the kingdom needed iron: burned villages, public hangings, hungry roads patrolled by men too frightened to think. I believed him, because cruelty pays captains well."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "And now you have seen what he fears. Not my sword. The truth. A prince who bleeds beside his people is harder to slander than to kill."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Ember",
"text": "Good. Let that truth spread faster than his warrants. My village has had enough of kings who only arrive to take."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Rowan",
"text": "It will spread. Teamsters gossip harder than priests pray, and I have ridden every road from here to the eastern hills. By sunrise, half the marches will know the prince bloodied one of Malrec's pet captains."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Brother Hale",
"text": "The old monastery lies east. Its bells once rang for mercy, and mercy is in short supply. If any sanctuary still remembers your father honestly, we may find it there."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "Bram",
"text": "Then we ride before Malrec sends a second dog pack."
}, {
"chapter": "Chapter 1: Exile in the Greenwood",
"speaker": "George",
"text": "East, then. For my father, for every house Malrec burned, and for every soul still too frightened to say his name aloud. We are finished running."
}]
next_chapter_id = "chapter_2"
