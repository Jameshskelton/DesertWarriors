event_triggers = [{
"dialogue_lines": [{
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "George",
"text": "Bartram's fall bought us a road, not a refuge. Malrec's men are still at our heels."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ysult",
"text": "Then we use the basin. Ten turns, no more. Hold the wash and do not let the raiders close the ring."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "George",
"text": "Ten turns in the teeth of the desert? You do know how to make a plan sound cheerful."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ysult",
"text": "Cheer is a luxury. Survival is the work."
}],
"id": "chapter_6_talk_george_ysult",
"trigger": "talk",
"unit_a_id": "george",
"unit_b_id": "ysult"
}, {
"dialogue_lines": [{
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ember",
"text": "Hunters above us, marauders below us, and enough sand to bury a kingdom."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Brother Hale",
"text": "Then let us at least make them work for the burial."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ember",
"text": "That is the bleakest encouragement I have heard all week."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Brother Hale",
"text": "And yet it moved you."
}],
"id": "chapter_6_talk_ember_hale",
"trigger": "talk",
"unit_a_id": "ember",
"unit_b_id": "brother_hale"
}, {
"dialogue_lines": [{
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Balt",
"text": "Tracks everywhere. They're driving us, not just chasing us."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Bram",
"text": "Then we bloody the hand on the whip and make them hesitate."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Balt",
"text": "Simple. Brutal. Efficient. You and Ysult really do sound alike."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Bram",
"text": "That may be the nicest thing anyone has said to me in days."
}],
"id": "chapter_6_talk_balt_bram",
"trigger": "talk",
"unit_a_id": "balt",
"unit_b_id": "bram"
}]
opening_dialogue = [{
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Narrator",
"text": "Bartram's death breaks the desert road, but not the hunt. Word races ahead of George's company, and before the caravan paths can offer shelter, fresh marauders and hired blades force the exiles deeper into the Hercule."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ysult",
"text": "Too many riders behind us and too much open sand ahead. We do not outrun this. We endure it."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Rowan",
"text": "There's a dry wash ahead, hemmed in by stone. Bad ground for a march. Better ground for a stand."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ricodial",
"text": "I object in principle to any plan whose best feature is 'slightly harder to die in.'"
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Brother Hale",
"text": "Principle noted. Hold it until sunset all the same."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "George",
"text": "Then we hold here for ten turns. If Malrec wants the desert itself to bury us, he can wait while we teach it patience."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Narrator",
"text": "Steel answers from the dunes. Shapes move along the ridges, and the basin below fills with the promise of another long night."
}]
victory_dialogue = [{
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Narrator",
"text": "By the tenth turn the company is ringed by bodies, broken axes, and dying light. The raiders draw back for one last rush - and then the desert answers with steel they never saw coming."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Narrator",
"text": "Warriors erupt from the dunes in a sheet of sand and blades, cutting through the marauders and breaking the ring around George's company before the bandits can understand what has found them."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Narrator",
"text": "The stories were true. The Griesha have come: the hidden desert clans who turn wasteland into fortress and silence into ambush."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Talis",
"text": "You held longer than most caravan guards manage with walls at their backs. That earns you water, if not wisdom. I am Talis, blade-chief of this Griesha band."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "George",
"text": "Then I owe you every life standing here. My uncle's hounds drove us into this basin. We mean to return the debt to him."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Talis",
"text": "Not tonight, you don't. Come to our camp. The desert is already testing whether you deserve to cross it, and you are not ready to answer yet."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Ysult",
"text": "She's right. If the Griesha are willing to shelter us, we would be fools to refuse."
}, {
"chapter": "Chapter 6: Teeth of the Dunes",
"speaker": "Narrator",
"text": "Under Griesha escort, George's company vanishes into the dunes, following Talis toward a hidden camp and the first real refuge they have known since exile."
}]
next_chapter_id = "chapter_7"
